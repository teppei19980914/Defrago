{
  "permissions": {
    "allow": [
      "Bash(python -m pytest:*)",
      "Bash(python -c \"import secrets; print\\(secrets.token_urlsafe\\(48\\)\\)\")",
      "Bash(where python3:*)",
      "Bash(where py:*)",
      "Bash(where uv:*)",
      "Bash(.venv/Scripts/python.exe -m pytest -x --timeout=60)",
      "Bash(.venv/Scripts/python.exe -m pytest -x)",
      "Bash(.venv/Scripts/python.exe -c \"from study_python.gtd.web.routers import iconbar; print\\('import ok'\\)\")",
      "Bash(.venv/Scripts/python.exe -c \"import httpx; print\\('httpx version:', httpx.__version__\\)\")",
      "Bash(.venv/Scripts/python.exe -m pytest)",
      "Bash(.venv/Scripts/python.exe -m ruff check .)",
      "Bash(.venv/Scripts/python.exe -m ruff format --check .)",
      "Bash(.venv/Scripts/python.exe -m pytest tests/gtd/web/test_iconbar.py tests/gtd/web/test_auth.py tests/gtd/web/test_inbox.py -x)",
      "Bash(.venv/Scripts/python.exe -m ruff format tests/gtd/web/test_auth.py tests/gtd/web/test_iconbar.py)",
      "Bash(.venv/Scripts/python.exe -c ':*)",
      "Bash(gh pr create --base main --title 'release: v3.1.0 - UX改善とお問い合わせ機能' --body ':*)",
      "Bash(.venv/Scripts/python.exe -m uv lock)",
      "Bash(C:/Users/SF02512/.local/bin/uv.exe lock:*)",
      "Bash(gh pr create --base main --title 'hotfix: v3.1.1 - httpx未インストールによるデプロイ失敗の修正' --body ':*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-branch-check.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-bash-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-lint.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-quality-gate.sh"
          }
        ]
      }
    ]
  }
}
